#include "extdll.h"
#include "util.h"
#include "cbase.h"
#include "player.h"

// =================== ACHIEVEMENT SPRITE ====================================

extern int gmsgStatusIconAchievement;

class CHudSpriteAchievement : public CBaseEntity
{
	DECLARE_CLASS(CHudSpriteAchievement, CBaseEntity);
public:
	void Spawn(void);
	void Precache(void);
	void Use(CBaseEntity* pActivator, CBaseEntity* pCaller, USE_TYPE useType, float value);
	STATE GetState(void) { return FBitSet(pev->spawnflags, SF_HUDSPR_ACTIVE) ? STATE_ON : STATE_OFF; }
	void StartMessage(CBasePlayer* pPlayer);
	void ShowAchievement(void);
	void Off(void);
	int x_update; // not used
	int y_update; // 0 means +1 to x coord, 1 means -1
	int x;
	int y;
	float UseTime;
	float WaitTime;

	DECLARE_DATADESC();
};

LINK_ENTITY_TO_CLASS(hud_sprite_achievement, CHudSpriteAchievement);

BEGIN_DATADESC(CHudSpriteAchievement)
	DEFINE_FIELD(x_update, FIELD_INTEGER),
	DEFINE_FIELD(y_update, FIELD_INTEGER),
	DEFINE_FIELD(x, FIELD_INTEGER),
	DEFINE_FIELD(y, FIELD_INTEGER),
	DEFINE_FIELD(UseTime, FIELD_TIME),
	DEFINE_FIELD(WaitTime, FIELD_TIME),
	DEFINE_FUNCTION(ShowAchievement),
	DEFINE_FUNCTION(Off),
END_DATADESC();

void CHudSpriteAchievement::Precache(void)
{
	PRECACHE_SOUND("misc/achievement.wav");
}

void CHudSpriteAchievement::Spawn(void)
{
	Precache();
	pev->rendercolor = Vector(255, 255, 255);
	y_update = 0;
	WaitTime = 8;
}


void CHudSpriteAchievement::Use(CBaseEntity* pActivator, CBaseEntity* pCaller, USE_TYPE useType, float value)
{
	if (!pActivator || !pActivator->IsPlayer())
		pActivator = UTIL_PlayerByIndex(1);

	EMIT_SOUND(pActivator->edict(), CHAN_VOICE, "misc/achievement.wav", 1, 0);

	y_update = 0;

	SetBits(pev->spawnflags, SF_HUDSPR_ACTIVE);

	y = 2;

	MESSAGE_BEGIN(MSG_ONE, gmsgStatusIconAchievement, NULL, pActivator->pev);
	WRITE_BYTE(GetState());
	WRITE_STRING(STRING(pev->model));
	WRITE_BYTE(pev->rendercolor.x);
	WRITE_BYTE(pev->rendercolor.y);
	WRITE_BYTE(pev->rendercolor.z);
	WRITE_BYTE(x);
	WRITE_BYTE(y);
	WRITE_BYTE(x_update);
	WRITE_BYTE(y_update);
	MESSAGE_END();

	y_update = 1;

	SetThink(&CHudSpriteAchievement::ShowAchievement);
	SetNextThink(WaitTime);
}

void CHudSpriteAchievement::ShowAchievement(void)
{
	CBaseEntity* pActivator = UTIL_PlayerByIndex(1);

	y = 2;

	MESSAGE_BEGIN(MSG_ONE, gmsgStatusIconAchievement, NULL, pActivator->pev);
	WRITE_BYTE(GetState());
	WRITE_STRING(STRING(pev->model));
	WRITE_BYTE(pev->rendercolor.x);
	WRITE_BYTE(pev->rendercolor.y);
	WRITE_BYTE(pev->rendercolor.z);
	WRITE_BYTE(x);
	WRITE_BYTE(y);
	WRITE_BYTE(x_update);
	WRITE_BYTE(y_update);
	MESSAGE_END();

	y_update = 1;

	UseTime = gpGlobals->time;

	SetThink(&CHudSpriteAchievement::Off);
	SetNextThink(0);
}

void CHudSpriteAchievement::Off(void)
{
	CBaseEntity* pActivator = UTIL_PlayerByIndex(1);

	if (gpGlobals->time > UseTime + 5)
	{
		ClearBits(pev->spawnflags, SF_HUDSPR_ACTIVE);
		MESSAGE_BEGIN(MSG_ONE, gmsgStatusIconAchievement, NULL, pActivator->pev);
		WRITE_BYTE(GetState());
		WRITE_STRING(0);
		WRITE_BYTE(pev->rendercolor.x);
		WRITE_BYTE(pev->rendercolor.y);
		WRITE_BYTE(pev->rendercolor.z);
		WRITE_BYTE(x_update);
		WRITE_BYTE(y_update);
		MESSAGE_END();
		//		ALERT(at_console, "OFF\n");
		SetThink(NULL);
		return;
	}

	SetThink(&CHudSpriteAchievement::Off);
	SetNextThink(0.1);
}