#include "extdll.h"
#include "util.h"
#include "cbase.h"
#include "player.h"
#include "game/gamerules.h"
#include "game/game.h"

// =====================TUTOR SPRITE=========================================

extern int gmsgStatusIconTutor;

#define SF_TUTOR_TOGGLE BIT(1)

class CHudSpriteTutor : public CBaseEntity
{
	DECLARE_CLASS(CHudSpriteTutor, CBaseEntity);
public:
	void Spawn(void);
	void Precache(void);
	void Use(CBaseEntity* pActivator, CBaseEntity* pCaller, USE_TYPE useType, float value);
	STATE GetState(void) { return FBitSet(pev->spawnflags, SF_HUDSPR_ACTIVE) ? STATE_ON : STATE_OFF; }
	void StartMessage(CBasePlayer* pPlayer);
	void KeyValue(KeyValueData* pkvd);
	void Off(void);
	int x_update; // 0 means +1 to x coord, 1 means -1
	int y_update; // currently it's not used anywhere
	int x;
	int y;
	float UseTime;

	void SimpleWait(void);
	float WaitTime;

	DECLARE_DATADESC();
};

LINK_ENTITY_TO_CLASS(hud_sprite_tutor, CHudSpriteTutor);

BEGIN_DATADESC(CHudSpriteTutor)
	DEFINE_FIELD(x_update, FIELD_INTEGER),
	DEFINE_FIELD(y_update, FIELD_INTEGER),
	DEFINE_FIELD(x, FIELD_INTEGER),
	DEFINE_FIELD(y, FIELD_INTEGER),
	DEFINE_FIELD(UseTime, FIELD_TIME),
	DEFINE_FUNCTION(Off),
	DEFINE_FUNCTION(SimpleWait),
	DEFINE_KEYFIELD(WaitTime, FIELD_TIME, "wait"),
END_DATADESC();

void CHudSpriteTutor::KeyValue(KeyValueData* pkvd)
{
	if (FStrEq(pkvd->szKeyName, "wait"))
	{
		WaitTime = Q_atof(pkvd->szValue);
		pkvd->fHandled = TRUE;
	}
	else
		CBaseEntity::KeyValue(pkvd);
}

void CHudSpriteTutor::Precache(void)
{
	PRECACHE_SOUND("misc/tutor.wav");
}

void CHudSpriteTutor::Spawn(void)
{
	if (sv_tutor.value == 0)
	{
		UTIL_Remove(this);
		return;
	}

	if (g_pGameRules->IsMultiplayer())
	{
		ALERT(at_aiconsole, "Tutorials are not allowed in multiplayer.\n");
		UTIL_Remove(this);
		return;
	}

	Precache();
	pev->rendercolor = Vector(255, 255, 255);
	x_update = 0;
	y = 2;

	if (!WaitTime || (WaitTime < 1))
		WaitTime = 7;
}

void CHudSpriteTutor::StartMessage(CBasePlayer* pPlayer) // this is called on saverestore
{
	if (GetState() == STATE_OFF) return; // inactive

//	ALERT(at_console, "%3d %3d %3d\n", x,y,x_update);

	MESSAGE_BEGIN(MSG_ONE, gmsgStatusIconTutor, NULL, pPlayer->pev);
	WRITE_BYTE(GetState());
	WRITE_STRING(STRING(pev->model));
	WRITE_BYTE(pev->rendercolor.x);
	WRITE_BYTE(pev->rendercolor.y);
	WRITE_BYTE(pev->rendercolor.z);
	if (x_update == 1)
		WRITE_BYTE(6); // x
	else if (x_update == 0)
		WRITE_BYTE(1); // x
	WRITE_BYTE(y);
	if (x_update == 1)
		WRITE_BYTE(0); // x_update
	else if (x_update == 0)
		WRITE_BYTE(1); // x_update
	WRITE_BYTE(y_update);
	MESSAGE_END();
}

void CHudSpriteTutor::Use(CBaseEntity* pActivator, CBaseEntity* pCaller, USE_TYPE useType, float value)
{
	if ((sv_tutor.value == 0) && (x_update == 0)) // let the active tutorial hide
		return;

	if (!pActivator || !pActivator->IsPlayer())
		pActivator = UTIL_PlayerByIndex(1);

	if (x_update == 0)
	{
		EMIT_SOUND(ENT(pev), CHAN_STATIC, "misc/tutor.wav", 1, 0);

		SetBits(pev->spawnflags, SF_HUDSPR_ACTIVE);

		x = 6;

		MESSAGE_BEGIN(MSG_ONE, gmsgStatusIconTutor, NULL, pActivator->pev);
			WRITE_BYTE(GetState());
			WRITE_STRING(STRING(pev->model));
			WRITE_BYTE(pev->rendercolor.x);
			WRITE_BYTE(pev->rendercolor.y);
			WRITE_BYTE(pev->rendercolor.z);
			WRITE_BYTE(x);
			WRITE_BYTE(y);
			WRITE_BYTE(x_update);
			WRITE_BYTE(y_update);
		MESSAGE_END();

		if (pev->spawnflags & SF_TUTOR_TOGGLE)
		{
			x_update = 1;
			SetThink(NULL);
		}
		else
		{
			SetThink(&CHudSpriteTutor::SimpleWait);
			SetNextThink(WaitTime);
		}
	}
	else
	{
		x = 1;

		MESSAGE_BEGIN(MSG_ONE, gmsgStatusIconTutor, NULL, pActivator->pev);
			WRITE_BYTE(GetState());
			WRITE_STRING(STRING(pev->model));
			WRITE_BYTE(pev->rendercolor.x);
			WRITE_BYTE(pev->rendercolor.y);
			WRITE_BYTE(pev->rendercolor.z);
			WRITE_BYTE(x);
			WRITE_BYTE(y);
			WRITE_BYTE(x_update);
			WRITE_BYTE(y_update);
		MESSAGE_END();
		x_update = 0;
		UseTime = gpGlobals->time;
		SetThink(&CHudSpriteTutor::Off);
		SetNextThink(0);
	}
}

void CHudSpriteTutor::SimpleWait(void)
{
	x_update = 1;
	Use(this, this, USE_TOGGLE, 0);
	return;
}

void CHudSpriteTutor::Off(void)
{
	CBaseEntity* pActivator = UTIL_PlayerByIndex(1);

	if (gpGlobals->time > UseTime + 5)
	{
		ClearBits(pev->spawnflags, SF_HUDSPR_ACTIVE);
		MESSAGE_BEGIN(MSG_ONE, gmsgStatusIconTutor, NULL, pActivator->pev);
		WRITE_BYTE(GetState());
		WRITE_STRING(STRING(pev->model));
		WRITE_BYTE(pev->rendercolor.x);
		WRITE_BYTE(pev->rendercolor.y);
		WRITE_BYTE(pev->rendercolor.z);
		WRITE_BYTE(x_update);
		WRITE_BYTE(y_update);
		MESSAGE_END();
		//		ALERT(at_console, "OFF\n");
		SetThink(NULL);
		return;
	}

	SetThink(&CHudSpriteTutor::Off);
	SetNextThink(0);
}